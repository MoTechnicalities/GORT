{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:gort:phase80-gauntlet-summary:v1",
  "title": "GORT Phase80 Gauntlet Summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "effective_schema_uri",
    "effective_schema_source",
    "manifest_signature",
    "checks",
    "overall",
    "phase62_integration_timeout_seconds",
    "deep_time"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "effective_schema_uri": {
      "type": "string",
      "minLength": 1
    },
    "effective_schema_source": {
      "type": "string",
      "enum": ["version", "override", "version-fallback"]
    },
    "manifest_signature": {
      "type": "string",
      "minLength": 1
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check", "result"],
        "properties": {
          "check": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": ["PASS", "FAIL"]
          }
        }
      }
    },
    "overall": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "phase62_integration_timeout_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "regression_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["regression_detected", "regression_messages", "regression_fields", "baseline_schema_version", "current_schema_version"],
      "properties": {
        "regression_detected": {
          "type": "boolean"
        },
        "regression_messages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "regression_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "baseline_schema_version": {
          "type": "string",
          "minLength": 1
        },
        "current_schema_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "phase12": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase12_verdict",
        "phase12_signature_hash",
        "phase12_operator_plan_size",
        "phase12_resonance_gate",
        "phase12_telemetry_digest"
      ],
      "properties": {
        "phase12_verdict": {
          "type": "string",
          "minLength": 1
        },
        "phase12_signature_hash": {
          "type": "string",
          "minLength": 1
        },
        "phase12_operator_plan_size": {
          "type": "string",
          "minLength": 1
        },
        "phase12_resonance_gate": {
          "type": "string",
          "minLength": 1
        },
        "phase12_telemetry_digest": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "phase12_drift_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "replay_loop_count",
        "baseline_available",
        "drift_detected",
        "drift_verdict",
        "drift_window",
        "signature_drift_detected",
        "telemetry_drift_detected",
        "baseline_signature_hash",
        "current_signature_hash",
        "baseline_telemetry_digest",
        "current_telemetry_digest"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "replay_loop_count": {
          "type": "integer",
          "minimum": 0
        },
        "baseline_available": {
          "type": "boolean"
        },
        "drift_detected": {
          "type": "boolean"
        },
        "drift_verdict": {
          "type": "string",
          "minLength": 1
        },
        "drift_window": {
          "type": "string",
          "minLength": 1
        },
        "signature_drift_detected": {
          "type": "boolean"
        },
        "telemetry_drift_detected": {
          "type": "boolean"
        },
        "baseline_signature_hash": {
          "type": "string",
          "minLength": 1
        },
        "current_signature_hash": {
          "type": "string",
          "minLength": 1
        },
        "baseline_telemetry_digest": {
          "type": "string",
          "minLength": 1
        },
        "current_telemetry_digest": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "phase13": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase13_verdict",
        "phase13_state_signature",
        "phase13_evolution_signature",
        "phase13_measurement_signature",
        "phase13_replay_loops"
      ],
      "properties": {
        "phase13_verdict": {
          "type": "string",
          "minLength": 1
        },
        "phase13_state_signature": {
          "type": "string",
          "minLength": 1
        },
        "phase13_evolution_signature": {
          "type": "string",
          "minLength": 1
        },
        "phase13_measurement_signature": {
          "type": "string",
          "minLength": 1
        },
        "phase13_replay_loops": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "phase14": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase14_verdict",
        "phase14_family_signature",
        "phase14_table_signature",
        "phase14_telemetry_digest",
        "phase14_replay_loops"
      ],
      "properties": {
        "phase14_verdict": {
          "type": "string",
          "minLength": 1
        },
        "phase14_family_signature": {
          "type": "string",
          "minLength": 1
        },
        "phase14_table_signature": {
          "type": "string",
          "minLength": 1
        },
        "phase14_telemetry_digest": {
          "type": "string",
          "minLength": 1
        },
        "phase14_replay_loops": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "phase15": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase15_verdict",
        "phase15_binding_signature",
        "phase15_sequence_signature",
        "phase15_telemetry_digest",
        "phase15_replay_loops"
      ],
      "properties": {
        "phase15_verdict": { "type": "string", "minLength": 1 },
        "phase15_binding_signature": { "type": "string", "minLength": 1 },
        "phase15_sequence_signature": { "type": "string", "minLength": 1 },
        "phase15_telemetry_digest": { "type": "string", "minLength": 1 },
        "phase15_replay_loops": { "type": "integer", "minimum": 0 }
      }
    },
    "phase16": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase16_verdict",
        "phase16_trajectory_signature",
        "phase16_telemetry_digest",
        "phase16_step_count",
        "phase16_replay_loops"
      ],
      "properties": {
        "phase16_verdict": { "type": "string", "minLength": 1 },
        "phase16_trajectory_signature": { "type": "string", "minLength": 1 },
        "phase16_telemetry_digest": { "type": "string", "minLength": 1 },
        "phase16_step_count": { "type": "integer", "minimum": 0 },
        "phase16_replay_loops": { "type": "integer", "minimum": 0 }
      }
    },
    "phase17": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase17_verdict",
        "semantic_signature",
        "semantic_digest",
        "replay_loops"
      ],
      "properties": {
        "phase17_verdict": { "type": "string", "minLength": 1 },
        "semantic_signature": { "type": "string", "minLength": 1 },
        "semantic_digest": { "type": "string", "minLength": 1 },
        "replay_loops": { "type": "integer", "minimum": 0 }
      }
    },
    "deep_time": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": {
              "const": false
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "min_loop_count",
            "max_loop_count",
            "loop_step",
            "cycles_per_loop",
            "drift_verdict",
            "drift_window",
            "drift_window_machine"
          ],
          "properties": {
            "enabled": {
              "const": true
            },
            "min_loop_count": {
              "type": "integer",
              "minimum": 2
            },
            "max_loop_count": {
              "type": "integer",
              "minimum": 2
            },
            "loop_step": {
              "type": "integer",
              "minimum": 1
            },
            "cycles_per_loop": {
              "type": "integer",
              "minimum": 2
            },
            "drift_verdict": {
              "type": "string",
              "minLength": 1
            },
            "drift_window": {
              "type": "string",
              "minLength": 1
            },
            "drift_window_machine": {
              "type": "object",
              "additionalProperties": false,
              "required": ["min_loop_count", "max_loop_count", "loop_step"],
              "properties": {
                "min_loop_count": {
                  "type": "integer",
                  "minimum": 2
                },
                "max_loop_count": {
                  "type": "integer",
                  "minimum": 2
                },
                "loop_step": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          }
        }
      ]
    }
  }
}
